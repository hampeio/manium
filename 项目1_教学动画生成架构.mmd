flowchart TB
    U["用户输入<br/>桥梁主题、图片、时长与质量"]

    subgraph P["教学规划层"]
        F["问题定框<br/>problem_frame.json"]
        O["教学大纲<br/>目标与知识顺序"]
        S["分镜与视觉计划<br/>旁白、对象、动作"]
        F --> O --> S
    end

    subgraph G["动画生成层"]
        C["ManimCE 代码生成"]
        Q["静态检查与视觉守卫"]
        R["Manim 分镜渲染"]
        C --> Q --> R
    end

    subgraph M["媒体与成果层"]
        A["字幕与音频处理"]
        V["片段拼接与视频导出"]
        D["项目资产<br/>分镜、源码、视频、日志"]
        A --> V --> D
    end

    E["修复闭环<br/>最多 3 轮"]

    U --> F
    S --> C
    R --> A
    Q -. 检查失败 .-> E
    R -. 渲染失败 .-> E
    E -. 修复后重试 .-> Q

    classDef main fill:#eef3f6,stroke:#45687f,color:#172633,stroke-width:1.5px;
    classDef guard fill:#edf4ef,stroke:#567663,color:#172633,stroke-width:1.5px;
    classDef output fill:#f5f1e8,stroke:#8a7546,color:#172633,stroke-width:1.5px;
    class U,F,O,S,C,R,A,V main;
    class Q,E guard;
    class D output;

