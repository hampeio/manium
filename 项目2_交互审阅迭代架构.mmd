flowchart TB
    I["项目1成果<br/>视频、shot_map、Manim 源码"]

    subgraph R["视频审阅层"]
        V["播放并暂停视频"]
        A["绘制编号批注<br/>矩形、箭头或画笔"]
        S["提交全局要求<br/>与局部标签"]
        V --> A --> S
    end

    subgraph C["上下文构建层"]
        M["根据 video_time<br/>匹配 shot_id"]
        X["提取截图、对象清单<br/>和目标 Scene 代码"]
        T["生成 Context JSON<br/>与 Agent Task"]
        M --> X --> T
    end

    subgraph P["局部修订层"]
        E["Codex / Agent<br/>仅修改目标 Scene"]
        G["重新渲染目标分镜"]
        F["更新完整预览<br/>并创建修订记录"]
        E --> G --> F
    end

    U{"用户验收"}
    OK["接受修订<br/>继续下一轮审阅"]
    RB["回滚到上一版本"]

    I --> V
    S --> M
    T --> E
    F --> U
    U -->|通过| OK
    U -. 不通过 .-> RB
    OK -. 继续批注 .-> V
    RB -. 恢复后重新审阅 .-> V

    classDef main fill:#eef3f6,stroke:#45687f,color:#172633,stroke-width:1.5px;
    classDef agent fill:#edf4ef,stroke:#567663,color:#172633,stroke-width:1.5px;
    classDef output fill:#f5f1e8,stroke:#8a7546,color:#172633,stroke-width:1.5px;
    class I,V,A,S,M,X,T,G,F main;
    class E agent;
    class U,OK,RB output;

